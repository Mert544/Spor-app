# ─── Supabase (Cloud Sync + Auth) ───────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# Without these vars the app works fully offline (guest mode only)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Kilo Gateway (AI Coach - Ücretsiz MiniMax M2.5) ───────────────────────
# No API key needed for free model! Kilo Gateway handles it automatically.
# Docs: https://kilo.ai/docs/gateway
KILO_GATEWAY_URL=https://api.kilo.ai/api/gateway